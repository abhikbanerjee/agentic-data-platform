# ─────────────────────────────────────────────────────────────────────────────
# AgenticDT Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# AWS credentials (use IAM user with least-privilege policy)
# For local dev you can use an AWS profile instead (comment out the keys below
# and set AWS_PROFILE to a profile name in ~/.aws/credentials).
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1
# AWS_PROFILE=agenticdt-dev   # alternative to keys above

# Pipeline resources (created by backend/aws/setup.sh)
PIPELINE_S3_BUCKET=your-bucket-name
PIPELINE_SFN_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:agenticdt-ingestion-pipeline
PIPELINE_GLUE_JOB=agenticdt-etl-pipeline
PIPELINE_PROFILER_LAMBDA=agenticdt-quality-profiler

# OpenAI
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_MODEL=gpt-4o

# Security
PIPELINE_PASSCODE=          # 4-digit code to guard pipeline triggers (leave blank = disabled locally)
ALLOWED_ORIGINS=http://localhost:5173

# Firebase (optional — leave blank to disable auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
